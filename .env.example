# -----------------------------
# App
# -----------------------------
APP_NAME=ClaudeOps Flow
ENVIRONMENT=local
DEBUG=true

# -----------------------------
# FastAPI
# -----------------------------
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Used by Streamlit frontend
FASTAPI_BASE_URL=http://api:8000

# If running Streamlit without Docker, use:
# FASTAPI_BASE_URL=http://127.0.0.1:8000

# -----------------------------
# Database
# -----------------------------
POSTGRES_USER=claudeops_user
POSTGRES_PASSWORD=claudeops_password
POSTGRES_DB=claudeops_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://claudeops_user:claudeops_password@postgres:5432/claudeops_db

# -----------------------------
# Demo Login
# -----------------------------
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123

DEMO_ANALYST_USERNAME=analyst
DEMO_ANALYST_PASSWORD=analyst123

# -----------------------------
# LLM Provider
# -----------------------------
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=replace_with_your_key
LLM_MODEL_NAME=claude-haiku-4-5

# -----------------------------
# Optional cost tracking
# -----------------------------
LLM_INPUT_COST_PER_1M_TOKENS=0.0
LLM_OUTPUT_COST_PER_1M_TOKENS=0.0

# -----------------------------
# Zapier / Make Integration
# -----------------------------
ZAPIER_HOOK_ENABLED=false
ZAPIER_WEBHOOK_URL=

MAKE_HOOK_ENABLED=false
MAKE_WEBHOOK_URL=

# -----------------------------
# Automation policy
# -----------------------------
ALLOW_EXTERNAL_AUTOMATION=false
