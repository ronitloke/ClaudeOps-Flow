APP_NAME=ClaudeOps Flow API
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

LLM_PROVIDER=claude

ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6

LLM_INPUT_COST_PER_1M_TOKENS=1.0
LLM_OUTPUT_COST_PER_1M_TOKENS=5.0

LLM_MAX_RETRIES=1
LLM_RETRY_DELAY_SECONDS=1.0

RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

DATABASE_URL=

FASTAPI_BASE_URL=

ENABLE_AUTOMATION_HOOKS=true
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=

ENABLE_ZAPIER_HOOK=true
ZAPIER_WEBHOOK_URL=

ENABLE_MAKE_HOOK=true
MAKE_WEBHOOK_URL=

DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123
DEMO_ANALYST_USERNAME=analyst
DEMO_ANALYST_PASSWORD=analyst123